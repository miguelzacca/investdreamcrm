// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
}

enum Temperature {
  COLD
  WARM
  HOT
}

enum FunnelStage {
  NEW_LEAD
  CONTACTED
  VIEWING_SCHEDULED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
}

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String
  role         Role     @default(AGENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  leads        Lead[]
  deals        Deal[]
}

model Lead {
  id           String      @id @default(uuid())
  agentId      String
  name         String
  whatsApp     String
  interest     String?
  temperature  Temperature @default(COLD)
  source       String?
  funnelStage  FunnelStage @default(NEW_LEAD)
  isArchived   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  
  agent        User        @relation(fields: [agentId], references: [id])
  deals        Deal[]
}

model Deal {
  id                     String   @id @default(uuid())
  leadId                 String
  agentId                String
  firstMonthCommission   Float?   // Comissao de primeiro aluguel
  recurringManagementFee Float?   // Taxa de administracao mensal (se houver)
  closedAt               DateTime @default(now())
  
  lead                   Lead     @relation(fields: [leadId], references: [id])
  agent                  User     @relation(fields: [agentId], references: [id])
}
