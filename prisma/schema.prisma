// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  AGENT
}

enum Temperature {
  COLD
  WARM
  HOT
}

enum FunnelStage {
  NEW_LEAD
  CONTACTED
  VIEWING_SCHEDULED
  NEGOTIATION
  CLOSED_WON
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  username             String    @unique
  email                String?   @unique
  passwordHash         String
  role                 Role      @default(AGENT)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  queueOrder           Int       @default(0)
  lastLeadReceivedAt   DateTime?
  inAutoQueue          Boolean   @default(true)
  whatsApp             String?
  leads                Lead[]
  deals                Deal[]
  pushSubscriptions    PushSubscription[]
  passwordResetTokens  PasswordResetToken[]
}

model Lead {
  id           String      @id @default(uuid())
  agentId      String
  name         String
  whatsApp     String
  interest     String?
  temperature  Temperature @default(COLD)
  source       String?
  funnelStage  FunnelStage @default(NEW_LEAD)
  isArchived    Boolean     @default(false)
  archiveReason String?
  isFollowUp    Boolean     @default(false)
  followUpDate  DateTime?
  expectedRentAmount Float?
  expectedCommission Float?
  createdAt     DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  firstContactedAt DateTime?
  lastContactedAt  DateTime?
  contactCount     Int         @default(0)
  
  agent        User        @relation(fields: [agentId], references: [id])
  deals        Deal[]
}

model Deal {
  id                     String   @id @default(uuid())
  leadId                 String
  agentId                String
  firstMonthCommission   Float?   // Comissao de primeiro aluguel
  recurringManagementFee Float?   // Taxa de administracao mensal (se houver)
  rentAmount             Float?   // Valor Bruto do Aluguel
  closedAt               DateTime @default(now())
  
  lead                   Lead     @relation(fields: [leadId], references: [id])
  agent                  User     @relation(fields: [agentId], references: [id])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


